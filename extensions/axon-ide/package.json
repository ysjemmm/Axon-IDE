        },
        {
          "command": "axon.skill.deleteBatch",
          "when": "view == axon.customSkills",
          "group": "navigation"
        },
        {
          "command": "axon.skill.create",
          "when": "view == axon.skills",
          "group": "navigation"
        },
        {
          "command": "axon.skill.import",
          "when": "view == axon.skills",
          "group": "navigation"
        },
        {
          "command": "axon.skill.deleteBatch",
