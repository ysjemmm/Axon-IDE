        "icon": "$(folder-opened)"
      },
      {
        "command": "axon.skill.deleteBatch",
        "title": "批量删除 Skill",
        "icon": "$(trash)"
      },
      {
        "command": "axon.skill.toggle",
        "title": "启用/禁用 Skill"
      },
      {
        "command": "axon.openPower",
        "title": "Axon: 打开 Power"
      },
      {
        "command": "axon.openMcp",
        "title": "Axon: 打开 MCP 管理",
        "icon": "$(plug)"
      },
      {
        "command": "axon.mcp.refresh",
        "title": "刷新 MCP",
        "icon": "$(refresh)"
      },
      {
        "command": "axon.mcp.delete",
        "title": "删除 MCP 服务器"
      },
      {
        "command": "axon.mcp.toggle",
        "title": "启用/禁用 MCP 服务器"
      },
      {
        "command": "axon.mcp.deleteAll",
        "title": "批量删除 MCP 服务器",
        "icon": "$(trash)"
      },
      {
        "command": "axon.power.create",
        "title": "新建 Power",
        "icon": "$(add)"
      },
      {
        "command": "axon.power.delete",
        "title": "删除 Power"
      },
      {
        "command": "axon.power.toggle",
        "title": "启用/禁用 Power"
      },
      {
        "command": "axon.power.import",
        "title": "导入 Power",
        "icon": "$(folder-opened)"
      },
      {
        "command": "axon.power.importSkills",
        "title": "导入 Skills 到此 Power",
        "icon": "$(file-symlink-directory)"
      },
      {
        "command": "axon.power.importSteering",
        "title": "导入 Steering 到此 Power",
        "icon": "$(file-text)"
      },
      {
        "command": "axon.openProvider",
        "title": "Axon: 打开 Provider 配置",
        "icon": "$(add)"
      },
      {
        "command": "axon.provider.refresh",
        "title": "刷新 Provider",
        "icon": "$(refresh)"
      },
      {
        "command": "axon.provider.setKey",
        "title": "设置 API Key",
        "icon": "$(key)"
      },
      {
        "command": "axon.provider.delete",
        "title": "删除 Provider"
      },
      {
        "command": "axon.git.toggleBlameAnnotation",
        "title": "使用 Git 追溯注解",
        "category": "Axon"
      },
      {
        "command": "axon.quickExplain",
        "title": "Axon: 解释这段代码",
        "category": "Axon"
      },
      {
        "command": "axon.quickFindBug",
        "title": "Axon: 检查这段代码有没有 bug",
        "category": "Axon"
      },
      {
        "command": "axon.quickTest",
        "title": "Axon: 为这段代码生成测试",
        "category": "Axon"
      },
      {
        "command": "axon.quickRefactor",
        "title": "Axon: 重构这段代码",
        "category": "Axon"
      }
    ],
    "menus": {
      "editor/lineNumber/context": [
        {
          "command": "axon.git.toggleBlameAnnotation",
          "group": "navigation@-100"
        }
      ],
      "view/item/context": [
        {
          "command": "axon.deleteRelay",
          "when": "viewItem == relayItem",
          "group": "inline"
        },
        {
          "command": "axon.skill.create",
          "when": "viewItem == skillGroup",
          "group": "navigation"
        },
        {
          "command": "axon.skill.import",
          "when": "viewItem == skillGroup",
          "group": "navigation"
        },
        {
          "command": "axon.skill.delete",
          "when": "viewItem == skillItem",
          "group": "7_modification"
        },
        {
          "command": "axon.skill.rename",
          "when": "viewItem == skillItem",
          "group": "7_modification"
        },
        {
          "command": "axon.skill.toggle",
          "when": "viewItem == skillToggleable",
          "group": "navigation"
        },
        {
          "command": "axon.skill.delete",
          "when": "viewItem == skillToggleable",
          "group": "7_modification"
        },
        {
          "command": "axon.power.toggle",
          "when": "viewItem == powerItem",
          "group": "navigation"
        },
        {
          "command": "axon.power.delete",
